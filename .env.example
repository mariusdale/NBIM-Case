# Copy to .env for live monitoring.
# Demo mode works without these keys when cached demo outputs are selected.

ANTHROPIC_API_KEY=

# Optional model overrides. Defaults match the requested pipeline:
# Haiku 4.5 for relevance, Sonnet 4.6 for summary and reviewer passes.
ANTHROPIC_RELEVANCE_MODEL=claude-haiku-4-5
ANTHROPIC_STRONG_MODEL=claude-sonnet-4-6
